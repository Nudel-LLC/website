{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint .",
    "lint:fix": "biome lint --fix .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "preview": "opennextjs-cloudflare build && wrangler dev --env alpha",
    "deploy:alpha": "opennextjs-cloudflare build && wrangler deploy --env alpha",
    "deploy:prod": "opennextjs-cloudflare build && wrangler deploy --env prod",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:smoke": "playwright test e2e/smoke.spec.ts",
    "e2e:install": "playwright install --with-deps"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.21",
    "@trpc/client": "^11.10.0",
    "@trpc/react-query": "^11.11.0",
    "@trpc/server": "^11.10.0",
    "@types/sanitize-html": "^2.16.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "microcms-js-sdk": "^3.3.0",
    "motion": "^12.34.3",
    "next": "16.1.6",
    "pino": "^10.3.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.9.3",
    "sanitize-html": "^2.17.1",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "overrides": {
    "fast-xml-parser": "5.4.2",
    "express-rate-limit": "8.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@opennextjs/cloudflare": "^1.16.5",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^28.1.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18",
    "wrangler": "^4.70.0"
  }
}

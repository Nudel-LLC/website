{
  "name": "nudel-website",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint .",
    "lint:fix": "biome lint --fix .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "preview": "opennextjs-cloudflare build && wrangler dev --env alpha",
    "deploy:alpha": "opennextjs-cloudflare build && wrangler deploy --env alpha",
    "deploy:preview": "opennextjs-cloudflare build && wrangler deploy --env preview",
    "deploy:prod": "opennextjs-cloudflare build && wrangler deploy --env prod",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:smoke": "playwright test e2e/smoke.spec.ts",
    "e2e:install": "playwright install --with-deps"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.100.9",
    "@trpc/client": "^11.16.0",
    "@trpc/react-query": "^11.17.0",
    "@trpc/server": "^11.16.0",
    "@types/sanitize-html": "^2.16.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "microcms-js-sdk": "^3.4.0",
    "motion": "^12.38.0",
    "next": "^16.2.6",
    "pino": "^10.3.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "resend": "^6.12.3",
    "sanitize-html": "^2.17.4",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.3.6"
  },
  "overrides": {
    "fast-xml-parser": "5.7.3",
    "express-rate-limit": "8.5.1",
    "@hono/node-server": "1.19.14",
    "hono": "4.12.18",
    "postcss": "8.5.14",
    "vite": "7.3.2",
    "undici": "7.25.0",
    "yaml": "2.8.3",
    "brace-expansion": "5.0.5",
    "minimatch@8.0.7": {
      "brace-expansion": "2.0.3"
    },
    "router": {
      "path-to-regexp": "8.4.0"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@opennextjs/cloudflare": "^1.19.11",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.1.5",
    "jsdom": "^29.1.1",
    "shadcn": "^4.7.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18",
    "wrangler": "^4.90.0"
  }
}
